# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (Railway provides DATABASE_URL automatically when Postgres is attached)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/collabhub

# Auth
JWT_SECRET=replace-with-a-32-byte-random-string
JWT_EXPIRES_IN=7d

# LLM (Anthropic Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
# Paste the entire .pem contents here. In Railway, paste multi-line as-is.
GITHUB_APP_PRIVATE_KEY=
